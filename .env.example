# Template for .env — copy to .env and fill in real values.
# .env is gitignored; .env.example is tracked.

# =============================================================================
# Consensus-Fade +1 Offset — Polymarket live execution (via Nautilus)
# =============================================================================

# --- 1) REQUIRED — Polygon EOA private key (0x-prefixed hex, 64 chars) -------
# The wallet that signs orders and holds your USDC.e collateral.
# Needs funding with a bit of POL (gas) and USDC.e (trading collateral).
# Use a FRESH wallet — don't reuse one with significant funds.
POLYMARKET_PK=""

# --- 2) DERIVED — L2 API credentials (auto-populated by `cfp setup`) ---------
# Deterministically derived from POLYMARKET_PK. Safe to lose — re-running
# `cfp setup` reproduces identical values.
POLYMARKET_API_KEY=""
POLYMARKET_API_SECRET=""
POLYMARKET_PASSPHRASE=""

# --- 3) OPTIONAL — proxy-wallet funder address ------------------------------
# Only needed if you use Polymarket's web/email-based wallet (signature_type=1)
# or a browser-wallet proxy contract (signature_type=2). For a raw EOA
# (signature_type=0, the default), leave this blank.
# POLYMARKET_FUNDER=""

# --- 4) OPTIONAL — Polygon RPC override (default: publicnode) ---------------
# If you see RPC timeouts during `cfp setup`, override with:
#   https://polygon-bor-rpc.publicnode.com  (default, public, works)
#   https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#   https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
# POLYMARKET_RPC=""

# =============================================================================
# Other data sources (unrelated to Polymarket execution)
# =============================================================================

# Kalshi (not used by Consensus-Fade — reserved for future strategies)
KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem

# Weather data (free + unauthenticated by default)
SYNOPTIC_API_TOKEN=

# AWS (NOAA Open Data buckets are anonymous — only needed for auth'd buckets)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
