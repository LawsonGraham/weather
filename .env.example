# Template for .env — copy to .env and fill in real values.
# .env is gitignored; .env.example is tracked.

# ============================================================================
# Consensus-Fade +1 Offset strategy — Polymarket live execution
# ============================================================================

# --- 1) REQUIRED — Polygon EOA private key (0x-prefixed hex, 64 chars) ------
# This is the wallet that signs orders and holds your USDC collateral.
# Needs: a few dollars of MATIC (gas) + USDC (trading capital).
# Create a FRESH wallet for this — don't reuse one with significant funds.
PK=""

# --- 2) DERIVED — L2 API credentials (auto-populated by `cfp setup`) --------
# These are deterministically derived from PK. Safe to lose — re-running
# `cfp setup` produces identical values.
CLOB_API_KEY=""
CLOB_SECRET=""
CLOB_PASS_PHRASE=""

# --- 3) OPTIONAL — Wallet architecture (advanced) ---------------------------
# 0 = EOA wallet (MetaMask, hardware wallet, or raw private key you control)
# 1 = Magic/email-linked wallet (Polymarket web signup)
# 2 = Browser-wallet proxy contract
# Leave at 0 unless you know otherwise.
CLOB_SIG_TYPE="0"

# Only needed if CLOB_SIG_TYPE != 0 (address holding USDC for proxy flows)
# CLOB_FUNDER=""

# --- 4) OPTIONAL — Polygon RPC endpoint (default: public polygon-rpc.com) ---
# The default public endpoint rate-limits aggressively. If you see timeouts or
# "rate limit exceeded" during `cfp setup`, override with one of:
#   https://polygon-bor-rpc.publicnode.com
#   https://polygon.meowrpc.com
#   https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
#   https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
# POLYGON_RPC=""

# ============================================================================
# Other data sources (pre-existing)
# ============================================================================

# --- Prediction markets ---
KALSHI_API_KEY_ID=
KALSHI_API_PRIVATE_KEY_PATH=./secrets/kalshi_private_key.pem
POLYMARKET_API_KEY=

# --- Weather data (most sources are free + unauthenticated) ---
# Only set if you end up using paid tiers:
SYNOPTIC_API_TOKEN=

# --- AWS (only if you need auth — NOAA Open Data buckets are anonymous) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
